                requested_quality=$(printf "360p\n480p\n720p\n1080p" | \
                    fzf --layout=reverse --cycle --prompt="–Т–Є–±–µ—А—Ц—В—М —П–Ї—Ц—Б—В—М: ")
                errors_only || printf "${BOLD}${BLUE}URL –њ–ї–µ—Ф—А—Г${NC} ($episode_title): ${CYAN}$player_url${NC}\n"
                if [ -n "$requested_quality" ]; then
                    new_episode_url=$(extract_episode_url "$player_url" "$requested_quality") || {
                        [ "$forced_quality" -eq 0] && requested_quality="" 
                        continue 
                    }
                    errors_only || printf "${BOLD}${BLUE}URL —Б–µ—А—Ц—Ч${NC} ($episode_title): ${CYAN}$new_episode_url${NC}\n"
                    [ "$force_flag" -eq 0 ] && errors_only || printf "${BOLD}${BLUE}–Ч–∞–Ї—А–Є–є—В–µ —Б–µ—А—Ц—О –≤ –њ—А–Њ–≥—А–∞–≤–∞—З—Ц —Й–Њ–± –њ—А–Њ–і–Њ–≤–ґ–Є—В–Є –≤–Є–Ї–Њ–љ–∞–љ–љ—П${NC}\n"
                    [ "$force_flag" -eq 0 ] && wait
                    episode_url=$new_episode_url
                    play_episode &
                    show_menu && return 0
                fi
                ;;
            "–Т–Є–є—В–Є")
                [ "$force_flag" -eq 0 ] && errors_only || printf "${BOLD}${BLUE}–Ч–∞–Ї—А–Є–є—В–µ —Б–µ—А—Ц—О –≤ –њ—А–Њ–≥—А–∞–≤–∞—З—Ц —Й–Њ–± –њ—А–Њ–і–Њ–≤–ґ–Є—В–Є –≤–Є–Ї–Њ–љ–∞–љ–љ—П${NC}\n"
                [ "$force_flag" -eq 0 ] && wait
                rm -f "$temp_episodes"
                return 0
                ;;
        esac
    done
}


case "$internal_player" in
    browser)
        if [ -n "$episode_range_start" ] && [ -n "$episode_range_end" ]; then
            episode_urls=$(sort -V "$temp_episodes" | awk -v start="$episode_range_start" -v end="$episode_range_end" '
                BEGIN { FS="\t" }
                NR > 0 { 
                    num = $1 + 0
                    if (num >= start + 0 && num <= end + 0) print $2
                }
            ')
            
            [ "$force_flag" -eq 1 ] && {
                printf '%s\n' "$episode_urls" | while read url; do
                    errors_only || printf "${BOLD}${BLUE}URL –њ–ї–µ—Ф—А—Г${NC}: ${CYAN}$url${NC}\n"
                    open_in_browser "$url" > /dev/null 2>&1
                done
            }
        else
            errors_only || printf "${BOLD}${BLUE}URL –њ–ї–µ—Ф—А—Г${NC} (${episode_title}): ${CYAN}$player_url${NC}\n"
            [ -n "$player_url" ] && open_in_browser "$player_url" > /dev/null 2>&1
        fi
        ;;
    mpv|vlc|iina)
        if [ -n "$episode_range_start" ] && [ -n "$episode_range_end" ]; then
            sort -V "$temp_episodes" | awk -v start="$episode_range_start" -v end="$episode_range_end" '
                BEGIN { FS="\t" }
                # –Ъ–Њ–љ–≤–µ—А—В—Г—Ф–Љ–Њ –≤ —З–Є—Б–ї–∞ –і–ї—П –њ—А–∞–≤–Є–ї—М–љ–Њ–≥–Њ –њ–Њ—А—Ц–≤–љ—П–љ–љ—П
                NR > 0 { 
                    num = $1 + 0
                    if (num >= start + 0 && num <= end + 0) print
                }
            ' | while IFS="$(printf '\t')" read -r ep_title ep_url; do
            errors_only || printf "${BOLD}${BLUE}–Т—Ц–і—В–≤–Њ—А—О—Ф–Љ–Њ —Б–µ—А—Ц—О${NC} ($ep_title): ${CYAN}$episode_url${NC}\n"
                episode_url=$(extract_episode_url "$ep_url" "$quality") && {
                    episode_title=$ep_title
                    player_url=$ep_url
                    play_episode
                    wait
                }
            done
        else
            [ -n "$episode_url" ] && {
                errors_only || printf "${BOLD}${MAGENTA}–Т—Ц–і—В–≤–Њ—А—О—Ф–Љ–Њ —Г $internal_player...${NC}\n"
                errors_only || printf "${BOLD}${BLUE}URL –њ–ї–µ—Ф—А—Г${NC} ($episode_title): ${CYAN}$player_url${NC}\n"
                errors_only || printf "${BOLD}${BLUE}URL —Б–µ—А—Ц—Ч${NC} ($episode_title): ${CYAN}$episode_url${NC}\n"
                play_episode & show_menu
            }
        fi
        ;;
    download)
        if [ -n "$episode_range_start" ] && [ -n "$episode_range_end" ]; then
            sort -V "$temp_episodes" | awk -v start="$episode_range_start" -v end="$episode_range_end" '
                BEGIN { FS="\t" }
                NR > 0 { 
                    num = $1 + 0
                    if (num >= start + 0 && num <= end + 0) print
                }
            ' | while IFS="$(printf '\t')" read -r ep_title ep_url; do
                errors_only || printf "${BOLD}${BLUE}–Ч–∞–≤–∞–љ—В–∞–ґ—Г—Ф–Љ–Њ —Б–µ—А—Ц—О${NC} ($ep_title): ${CYAN}$episode_url${NC}\n"
                episode_url=$(extract_episode_url "$ep_url" "$quality") && {
                    download "$episode_url" "${anime_title}_${ep_title}"
                }
            done
        else
            selected_episode=$(sort -V "$temp_episodes" | \
                fzf --layout=reverse \
                    --prompt="–Т–Є–±–µ—А—Ц—В—М —Б–µ—А—Ц—О –і–ї—П –Ј–∞–≤–∞–љ—В–∞–ґ–µ–љ–љ—П: " \
                    --delimiter='\t' \
                    --cycle \
                    --with-nth=1)
            
            [ -n "$selected_episode" ] && {
                episode_title=$(printf '%s' "$selected_episode" | cut -f1)
                player_url=$(printf '%s' "$selected_episode" | cut -f2)
                episode_url=$(extract_episode_url "$player_url" "$quality") && {
                    errors_only || printf "${BOLD}${MAGENTA}–Ч–∞–≤–∞–љ—В–∞–ґ—Г—Ф–Љ–Њ...${NC}\n"
                    download "$episode_url" "${anime_title}_${episode_title}"
                }
            }
        fi
        ;;
esac
