#!/bin/sh

anitube_base="https://anitube.in.ua"
api_url="https://anitube.in.ua/engine/ajax/playlists.php"

RED='\033[31m'
BLUE='\033[34m'
MAGENTA='\033[35m'
CYAN='\033[36m'
BOLD='\033[1m'
NC='\033[0m'

query=""
force_flag=0
errors_mode=0
anime_url=""
continued_url=""
internal_player=""
episode_number=""
episode_range_start=""
episode_range_end=""
download_dir="."
debug=""
thistory="$HOME/.local/state/ani-ukr/history"
requested_quality=""
forced_quality=0
version=1.5.1

version_info() {
    printf "–Т–µ—А—Б—Ц—П ${version}\n"
}

errors_only() {
    [ "$errors_mode" -eq 0 ] && return 1 || return 0
}

update() {
    script_path="$0"
    [ ! -w "$script_path" ] && printf "${RED}–Э–µ–Љ–∞—Ф –њ—А–∞–≤ –љ–∞ –Ј–∞–њ–Є—Б –і–Њ $script_path${NC}\n" && return 1

    latest_version=$(curl -s "https://raw.githubusercontent.com/Gridi-1143/ani-ukr/main/ani-ukr" | grep -m1 'version=' | cut -d'=' -f2)
    [ -z "$latest_version" ] && printf "${RED}–Я–Њ–Љ–Є–ї–Ї–∞ –Њ—В—А–Є–Љ–∞–љ–љ—П –≤–µ—А—Б—Ц—Ч${NC}\n" && return 1

    if [ "$version" = "$latest_version" ]; then
        errors_only || printf "${BOLD}${BLUE}–£ –≤–∞—Б –≤–ґ–µ –Њ—Б—В–∞–љ–љ—П –≤–µ—А—Б—Ц—П${NC}\n"
        return 0
    fi

    curl -s "https://raw.githubusercontent.com/Gridi-1143/ani-ukr/main/ani-ukr" > "$script_path" && \
    chmod +x "$script_path" && \
    errors_only || printf "${BOLD}${BLUE}–Ю–љ–Њ–≤–ї–µ–љ–Њ –і–Њ –≤–µ—А—Б—Ц—Ч $latest_version${NC}\n"
}

continue_ep() {
    [ ! -s "$thistory" ] && {
        printf "${RED}–Ж—Б—В–Њ—А—Ц—П –њ–µ—А–µ–≥–ї—П–і—Ц–≤ –њ–Њ—А–Њ–ґ–љ—П.${NC}\n" >&2
        return 1
    }

    selected_line=$(cat "$thistory" | \
        awk '{url=$NF; $NF=""; print $0 "\t" url}' | \
        fzf --delimiter='\t' --with-nth=1 --prompt="–Ю–±–µ—А—Ц—В—М –∞–љ—Ц–Љ–µ –і–ї—П –њ—А–Њ–і–Њ–≤–ґ–µ–љ–љ—П: " --layout=reverse --cycle)

    [ -z "$selected_line" ] && {
        return 1
    }
    echo "$selected_line" | awk '{print $NF}'
}

help_info() {
    printf "%s\n" "\
–Т–Є–Ї–Њ—А–Є—Б—В–∞–љ–љ—П: ${0##*/} [–Я–†–Р–Я–Ю–†–¶–Ж] [–Ч–Р–Я–Ш–Ґ]

–Я—А–∞–њ–Њ—А—Ж—Ц:
    -u, --url      URL     –Т–Є–Ї–Њ—А–Є—Б—В–∞—В–Є URL –∞–љ—Ц–Љ–µ –Ј–∞–Љ—Ц—Б—В—М –љ–∞–Ј–≤–Є.
    -q, --quality  –ѓ–Ъ–Ж–°–Ґ–ђ  –Ч–Љ—Ц–љ–Є—В–Є —П–Ї—Ц—Б—В—М –≤—Ц–і–µ–Њ (–љ–∞–њ—А. 720p, 1080p).
    -e, --episode  N       –Ъ–Њ–љ–Ї—А–µ—В–љ–Є–є –µ–њ—Ц–Ј–Њ–і.
    -r, --range    N..M    –Ю–±—А–∞—В–Є –Ї—Ц–ї—М–Ї–∞ —Б–µ—А—Ц–є,
                           –Љ–Њ–ґ–љ–∞ –њ—А–Њ–≥—А–∞—В–Є/–Ј–∞–≤–∞–љ—В–∞–ґ–Є—В–Є —Б–µ—А—Ц—Ч –Ј N –њ–Њ M.
    -v, --vlc              –Т–Є–Ї–Њ—А–Є—Б—В–Њ–≤—Г–≤–∞—В–Є vlc.
    -m, --mpv              –Т–Є–Ї–Њ—А–Є—Б—В–Њ–≤—Г–≤–∞—В–Є mpv.
    -i, --iina             –Т–Є–Ї–Њ—А–Є—Б—В–Њ–≤—Г–≤–∞—В–Є iina.
    -b, --browser          –Т–Є–Ї–Њ—А–Є—Б—В–Њ–≤—Г–≤–∞—В–Є –±—А–∞—Г–Ј–µ—А.
    -d, --download         –Ч–∞–≤–∞–љ—В–∞–ґ–Є—В–Є —Б–µ—А—Ц—О –Ј–∞–Љ—Ц—Б—В—М –њ–µ—А–µ–≥–ї—П–і—Г.
    -dd, --download-dir    –Т–Ї–∞–Ј–∞—В–Є –і–Є—А–µ–Ї—В–Њ—А—Ц—О –і–ї—П –Ј–∞–≤–∞–љ—В–∞–ґ–µ–љ–љ—П.
    -D, --debug            –Ч–∞–њ–Є—Б—Г–≤–∞—В–Є –µ—В–∞–њ–Є –≤–Є–Ї–Њ–љ–∞–љ–љ—П –≤ debug.txt.
    -E, --errors           –Э–µ –њ–Њ–Ї–∞–Ј—Г–≤–∞—В–Є –њ–Њ–≤—Ц–і–Њ–Љ–ї–µ–љ–љ—П —П–Ї—Й–Њ —Ж–µ –љ–µ –њ–Њ–Љ–Є–ї–Ї–∞.
    -c, --continue         –Т—Ц–і–Њ–±—А–∞–Ј–Є—В–Є —Ц—Б—В–Њ—А—Ц—О –њ–µ—А–µ–≥–ї—П–і—Г
    -C, --clear            –Ю—З–Є—Б—В–Є—В–Є —Ц—Б—В–Њ—А—Ц—О –њ–µ—А–µ–≥–ї—П–і—Г
    -f, --force            –Т—Ц–і–Ї—А–Є—В–Є –њ–Њ—Б–Є–ї–∞–љ–љ—П –Њ–і–љ–Њ—З–∞—Б–љ–Њ –∞ –љ–µ –њ–Њ—З–µ—А–≥–Њ–≤–Њ,
                           –Т–Є–Ї–Њ—А–Є—Б—В–Њ–≤—Г–≤–∞—В–Є –ї–Є—И–µ –Ј -r —В–∞ -b,
                           –Т–Є–Ї–Њ—А–Є—Б—В–Њ–≤—Г–є—В–µ –Њ–±–µ—А–µ–ґ–љ–Њ, –±–Њ –≤ –±—А–∞—Г–Ј–µ—А—Ц –≤—Ц–і–Ї—А–Є–≤–∞—Ф –±–∞–≥–∞—В–Њ –≤–Ї–ї–∞–і–Њ–Ї.
    -U, --update           –Ю–љ–Њ–≤–Є–љ–Є—В–Є ${0##*/}
    -V, --version          –Т—Ц–і–Њ–±—А–∞–Ј–Є—В–Є –њ–Њ—В–Њ—З–љ—Г –≤–µ—А—Б—Ц—О ${0##*/}.
    -h, --help             –Т—Ц–і–Њ–±—А–∞–Ј–Є—В–Є —Ж–µ –њ–Њ–≤—Ц–і–Њ–Љ–ї–µ–љ–љ—П.
–Я—А–Є–Ї–ї–∞–і–Є:
    ${0##*/} -v –Э–∞—А—Г—В–Њ
    ${0##*/} -d -D . -r 2..5 –Ф–∞–љ–і–∞–і–∞–љ
    ${0##*/} -r 1..3 -bf -u https://anitube.in.ua/3541-mzhvidov-oglyadach.html"
}

while [ $# -gt 0 ]; do
    case "$1" in
        -u|--url) 
            shift
            if [ $# -eq 0 ]; then
                printf "${RED}–Т–Ї–∞–ґ—Ц—В—М URL${NC}\n"
                exit 1
            fi
            anime_url="$1"
            ;;
        -q|--quality)
            shift
            if [ $# -eq 0 ]; then
                printf "${RED}–Ч–∞–і–∞–є—В–µ –Ј–љ–∞—З–µ–љ–љ—П —П–Ї–Њ—Б—В—Ц${NC}\n"
                exit 1
            fi
            quality="$1"
            forced_quality=1
            ;;
        -e|--episode)
            shift
            if [ $# -eq 0 ]; then
                printf "${RED}–Э–Њ–Љ–µ—А –µ–њ—Ц–Ј–Њ–і—Г –≤—Ц–і—Б—Г—В–љ—Ц–є${NC}\n"
                exit 1
            fi
            episode_number="$1"
            ;;
        -r|--range)
            shift
            if [ $# -eq 0 ]; then
                printf "${RED}–Ф—Ц–∞–њ–∞–Ј–Њ–љ –µ–њ—Ц–Ј–Њ–і—Ц–≤ –≤—Ц–і—Б—Г—В–љ—Ц–є${NC}\n" >&2
                exit 1
            fi
            episode_range_start=$(printf '%s' "$1" | cut -d'.' -f1)
            episode_range_end=$(printf '%s' "$1" | cut -d'.' -f3)
            if [ -z "$episode_range_start" ] || [ -z "$episode_range_end" ]; then
                printf "${RED}–Э–µ–њ—А–∞–≤–Є–ї—М–љ–Є–є —Д–Њ—А–Љ–∞—В –і—Ц–∞–њ–∞–Ј–Њ–љ—Г. –Т–Є–Ї–Њ—А–Є—Б—В–Њ–≤—Г–є—В–µ —Д–Њ—А–Љ–∞—В N..M${NC}\n" >&2
                exit 1
            fi
            ;;
        -dd|--download-dir)
            shift
            if [ $# -eq 0 ]; then
                printf "${RED}–Т–Ї–∞–ґ—Ц—В—М –і–Є—А–µ–Ї—В–Њ—А—Ц—О –і–ї—П –Ј–∞–≤–∞–љ—В–∞–ґ–µ–љ–љ—П${NC}\n" >&2
                exit 1
            fi
            download_dir="$1"
            ;;
        -E|--errors) errors_mode=1 ;;
        -c|--continue)
            continued_url=$(continue_ep)
            if [ -n "$continued_url" ]; then
                anime_url="$continued_url"
            else
                exit 0
            fi
            ;;
        -C|--clean) rm -f $thistory && printf "${BLUE}–Ж—Б—В–Њ—А—Ц—О –Њ—З–Є—Й–µ–љ–Њ${NC}\n" && exit 0;;
        --vlc) internal_player="vlc" ;;
        --mpv) internal_player="mpv" ;;
        --iina) internal_player="iina" ;;
        --browser) internal_player="browser" ;;
        --download) internal_player="download" ;;
        --debug) debug="1" ;;
        --force) force_flag=1 ;;
        -U|--update) update; exit 0 ;;
        -V|--version) version_info; exit 0 ;;
        -h|--help) help_info; exit 0 ;;
        -[vmibdDCf]*)
            flag=${1#-}
            while [ -n "$flag" ]; do
                case "${flag%"${flag#?}"}" in
                    v) internal_player="vlc" ;;
                    m) internal_player="mpv" ;;
                    i) internal_player="iina" ;;
                    b) internal_player="browser" ;;
                    d) internal_player="download" ;;
                    D) debug="1" ;;
                    f) force_flag=1 ;;
                    E) errors_mode=1 ;;
                    *) printf "${RED}–Э–µ–≤—Ц–і–Њ–Љ–Є–є –њ–∞—А–∞–Љ–µ—В—А: %s${NC}\n" "$flag" >&2; exit 1 ;;
                esac
                flag=${flag#?}
            done
            ;;
        -*)
            printf "${RED}–Э–µ–≤—Ц–і–Њ–Љ–Є–є –њ–∞—А–∞–Љ–µ—В—А: $1${NC}\n"
            help_info
            exit 1
            ;;
        *)
            query="$query $1"
            ;;
    esac
    shift
done

query=$(printf "%s" "$query" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')


set_internal_player() {
    [ -n "$internal_player" ] && {
        case "$internal_player" in
            mpv)
                [ -x $(command -v mpv >/dev/null 2>&1) ] || {
                    printf "${RED}mpv –љ–µ –Ј–љ–∞–є–і–µ–љ–Њ${NC}\n" >&2
                    exit 1
                }
                ;;
            vlc)
                [ -x $(command -v vlc >/dev/null 2>&1) ] || {
                    printf "${RED}vlc –љ–µ –Ј–љ–∞–є–і–µ–љ–Њ${NC}\n" >&2
                    exit 1
                }
                ;;
            iina)
                [ -x $(command -v iina >/dev/null 2>&1) ] || {
                    printf "${RED}iina –љ–µ –Ј–љ–∞–є–і–µ–љ–Њ${NC}\n" >&2
                    exit 1
                }
                ;;
        esac
        return 0
    }
    command -v iina >/dev/null 2>&1 && internal_player="iina" && return 0
    command -v mpv >/dev/null 2>&1 && internal_player="mpv" && return 0
    command -v vlc >/dev/null 2>&1 && internal_player="vlc" && return 0
    printf "${RED}–Э–µ –Ј–љ–∞–є–і–µ–љ–Њ –њ—Ц–і—В—А–Є–Љ—Г–≤–∞–љ–Є—Е –≤—Ц–і–µ–Њ–њ–ї–µ—Ф—А—Ц–≤. –Т—Б—В–∞–љ–Њ–≤—Ц—В—М iina, mpv –∞–±–Њ vlc${NC}\n" >&2
    exit 1
}

extract_episode_url() {
    player_url="$1"
    requested_quality="$2"
    
    html_content=$(curl -s "$player_url" \
        -H "User-Agent: Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/91.0.4472.124 Safari/537.36" \
        -H "Referer: https://anitube.in.ua/" \
        -H "Accept: text/html,application/xhtml+xml,application/xml;q=0.9,image/webp,*/*;q=0.8" \
        -H "Accept-Language: uk-UA,uk;q=0.8,en-US;q=0.5,en;q=0.3")
    
    [ -z "$html_content" ] && {
        printf "${RED}–Я–Њ–Љ–Є–ї–Ї–∞ –Ј–∞–≤–∞–љ—В–∞–ґ–µ–љ–љ—П —Б—В–Њ—А—Ц–љ–Ї–Є –њ–ї–µ—Ф—А–∞${NC}\n" >&2
        return 1
    }

    # –Я–Њ—И—Г–Ї –≤—Ц–і–µ–Њ URL –≤ —А—Ц–Ј–љ–Є—Е —Д–Њ—А–Љ–∞—В–∞—Е
    avail_quality=$(printf '%s' "$html_content" | sed -n '
        s/.*file:[[:space:]]*'\''\([^'\'']*\)'\''.*/\1/p;
        s/.*file:[[:space:]]*"\([^"]*\)".*/\1/p;
        s/.*src="\([^"]*\.m3u8[^"]*\)".*/\1/p;
        s/.*url:[[:space:]]*"\([^"]*\)".*/\1/p;
        s/.*src:[[:space:]]*"\([^"]*\)".*/\1/p
    ')

    quality=$(printf '%s' "$avail_quality" | sed -n "s/.*\[$requested_quality\]\([^,]*\).*/\1/p")
    [ -n "$debug" ] && echo -e "[D] url with avail_quality: $avail_quality\n[D] req_quality: $requested_quality\n[D] ep_quality: $quality\n" >> $download_dir/debug.txt

    case "$avail_quality" in
        # –§–Њ—А–Љ–∞—В –Ј —П–Ї–Њ—Б—В—П–Љ–Є [720p]url,[1080p]url
        *'['*']'*)
            if [ -n "$requested_quality" ] && [ -z "$quality" ]; then
                printf "${RED}–®—Г–Ї–∞–љ—Г —П–Ї—Ц—Б—В—М ($requested_quality) –љ–µ –≤–і–∞–ї–Њ—Б—П –Ј–љ–∞–є—В–Є, –≤–Є–Ї–Њ—А–Є—Б—В–Њ–≤—Г—Ф–Љ–Њ –љ–∞–є–Ї—А–∞—Й—Г –і–Њ—Б—В—Г–њ–љ—Г${NC}\n" >&2
                [ "$forced_quality" -eq 0 ] && requested_quality=""
            elif [ -n "$requested_quality" ];then
                episode_url="$quality"
                break
            fi
            episode_url=$(printf '%s' "$avail_quality" | rev | cut -d',' -f1 | rev | sed 's|^\[.*\]||')
            ;;
        *mp4upload.com*)
            [ -n "$requested_quality" ] && {
                printf "${RED}–ѓ–Ї—Ц—Б—В—М –і–ї—П —Ж—М–Њ–≥–Њ –њ–ї–µ—Ф—А—Г –Њ–±—А–∞—В–Є –љ–µ –Љ–Њ–ґ–љ–∞${NC}\n" >&2
                sleep 2
                return 1
            }
            [ "$internal_player" = "vlc" ] && {
                printf "${RED}VLC –љ–µ –Љ–Њ–ґ–µ –≤—Ц–і—В–≤–Њ—А—О–≤–∞—В–Є –њ–ї–µ—Ф—А MP4\n${NC}" >&2
                sleep 2
                return 1
            }
            mp4_id=$(printf '%s' "$html_content" | sed -n 's/.*embed-\([^"]*\)\.html.*/\1/p')
            [ -z "$mp4_id" ] && {
                mp4_id=$(printf '%s' "$html_content" | sed -n 's/.*mp4upload\.com\/\([^"]*\)".*/\1/p')
            }
            [ -n "$mp4_id" ] && {
                episode_url="https://mp4upload.com/embed-$mp4_id.html"
            }
            ;;
            #–љ–µ–≤—Ц–і–Њ–Љ–Є–є –њ–ї–µ—Ф—А
        *) 
            [ -n "$requested_quality" ] && [ -z "$quality" ] && {
                printf "${RED}–®—Г–Ї–∞–љ—Г —П–Ї—Ц—Б—В—М ($requested_quality) –љ–µ –≤–і–∞–ї–Њ—Б—П –Ј–љ–∞–є—В–Є, –≤–Є–Ї–Њ—А–Є—Б—В–Њ–≤—Г—Ф–Љ–Њ –љ–∞–є–Ї—А–∞—Й—Г –і–Њ—Б—В—Г–њ–љ—Г${NC}\n" >&2
                [ "$forced_quality" -eq 0 ] && requested_quality=""
            }
            episode_url="$avail_quality"
            ;;
    esac

    if [ -n "$episode_url" ]; then
        printf '%s\n' "$episode_url"
        return 0
    else
        printf "${RED}–Э–µ –≤–і–∞–ї–Њ—Б—П –Њ—В—А–Є–Љ–∞—В–Є URL –≤—Ц–і–µ–Њ${NC}\n" >&2
        return 1
    fi
}

download() {
    url="$1"
    filename="$2"
    
    [ ! -d "$download_dir" ] && {
        printf "${RED}–Ф–Є—А–µ–Ї—В–Њ—А—Ц—П $download_dir –љ–µ —Ц—Б–љ—Г—Ф${NC}\n" >&2
        return 1
    }

    case "$url" in
        *m3u8*)
            if command -v yt-dlp >/dev/null 2>&1; then
            yt-dlp "$url" \
                --no-skip-unavailable-fragments \
                --fragment-retries infinite \
                --retries infinite \
                --force-keyframes-at-cuts \
                --concurrent-fragments 16 \
                --rm-cache-dir \
                -o "$download_dir/$filename.mp4"
            else
                ffmpeg -loglevel error -stats \
                    -i "$url" -c copy "$download_dir/$filename.mp4"
            fi
            ;;
        *)
            aria2c --enable-rpc=false --check-certificate=false \
                --continue --summary-interval=0 -x 16 -s 16 \
                "$url" --dir="$download_dir" -o "$filename.mp4" \
                --download-result=hide
            ;;
    esac
}

extract_news_id() {
  url="$1"
  echo "$url" | grep -oP '(?<=/)\d+(?=-)'
}

extract_user_hash() {
  url="$1"
  html=$(curl -s "$url")

  [ -z "$html" ] && {
      printf "${RED}–Э–µ –≤–і–∞–ї–Њ—Б—П –Њ—В—А–Є–Љ–∞—В–Є HTML-–Ї–Њ–і –Ј –њ–Њ—Б–Є–ї–∞–љ–љ—П${NC}: $url"
      return 1
  }

  echo "$html" | grep -oP 'var dle_login_hash = '\''\K[^'\'']+'
}

anitube_search() {
  query=$(printf "%s" "$1" | sed 's| |+|g')
  search_start=1
  result_from=1
  per_page=10
  result_count=1

  initial_result=$(curl -s "$anitube_base/index.php?do=search" \
    -H "Content-Type: application/x-www-form-urlencoded" \
    -H "User-Agent: Mozilla/5.0 (X11; Linux x86_64; rv:133.0) Gecko/20100101 Firefox/133.0" \
    --data-raw "do=search&subaction=search&search_start=$search_start&full_search=0&result_from=$result_from&story=$query")

  total_results=$(printf "%s" "$initial_result" | grep -oP '(?<=–Ч–∞ –Т–∞—И–Є–Љ –Ј–∞–њ–Є—В–Њ–Љ –Ј–љ–∞–є–і–µ–љ–Њ )\d+')
  total_pages=$(( (total_results + per_page - 1) / per_page ))

  while [ $search_start -le $total_pages ]; do
    initial_result=$(curl -s "$anitube_base/index.php?do=search" \
      -H "Content-Type: application/x-www-form-urlencoded" \
      -H "User-Agent: Mozilla/5.0 (X11; Linux x86_64; rv:133.0) Gecko/20100101 Firefox/133.0" \
      --data-raw "do=search&subaction=search&search_start=$search_start&full_search=0&result_from=$result_from&story=$query")

    links=$(printf "%s" "$initial_result" | sed -n 's|.*<h2[^>]*><a href="\([^"]*\)">.*|\1|p')
    titles=$(printf "%s" "$initial_result" | sed -n 's|.*<h2[^>]*><a href="[^"]*">\([^<]*\)</a>.*|\1|p')
    types=$(printf "%s" "$initial_result" | grep -oP '(?<=<div class=")[^"]*(?=" style="float:right;">)' | grep -E 'ukr|sub|dubsub')

    [ -z "$links" ] || [ -z "$titles" ] && break

    set -f
    IFS='
'
    links_array=$(echo "$links")
    titles_array=$(echo "$titles") 
    types_array=$(echo "$types")

    i=0
    for link in $links_array; do
      title=$(echo "$titles_array" | sed -n "$((i + 1))p")
      type=$(echo "$types_array" | sed -n "$((i + 1))p")
      
      case "$type" in
          ukr) type_text="(DUB)";;
          sub) type_text="(SUB)";;
          dubsub) type_text="(D+S)";;
        *) type_text="N/A";;
      esac
      
      printf "%d. %s\t%s\t%s\n" "$result_count" "$title" "$link" "$type_text"
      result_count=$((result_count + 1))
      i=$((i + 1))
    done
    set +f

    search_start=$((search_start + 1))
    result_from=$((result_from + per_page))

    [ $search_start -le $total_pages ] && {
        echo "----------"
    }
  done

  [ $result_count -eq 1 ] && {
      printf "${RED}–Э—Ц—З–Њ–≥–Њ –љ–µ –Ј–љ–∞–є–і–µ–љ–Њ –і–ї—П –Ј–∞–њ–Є—В—Г${NC}: $query"
      exit 1
  }
}

# –Ч—Ц–±—А–∞—В–Є —Ц–љ—Д—Г –њ—А–Њ –њ–ї—Ф–µ—А 
fetch_playlist() {
  url="$1"
  news_id=$(extract_news_id "$url")
  user_hash=$(extract_user_hash "$url")

  response=$(curl -s -X GET "$api_url?news_id=$news_id&xfield=playlist&user_hash=$user_hash" \
    -H "Referer: $url" \
    -H "User-Agent: Mozilla/5.0 (X11; Linux x86_64; rv:133.0) Gecko/20100101 Firefox/133.0" \
    -H "X-Requested-With: XMLHttpRequest" \
    -H "Accept: application/json, text/javascript, */*; q=0.01")

  if printf '%s' "$response" | grep -q '"success":false'; then
    page_html=$(curl -s -L --post302 \
      -H "User-Agent: Mozilla/5.0 (X11; Linux x86_64; rv:133.0) Gecko/20100101 Firefox/133.0" \
      -H "Accept: text/html,application/xhtml+xml,application/xml;q=0.9,image/webp,*/*;q=0.8" \
      "$url")

    response=$(printf '%s' "$page_html" | sed -n 's/.*\(RalodePlayer\.init(.*)\);.*/\1/p' | head -1)
    
    [ -z "$response" ] && {
      printf "${RED}–Э–µ –≤–і–∞–ї–Њ—Б—П –Ј–љ–∞–є—В–Є —Б–њ–Є—Б–Њ–Ї —Б–µ—А—Ц–є${NC}\n" >&2 
      return 1
    }

    printf "html\n%s\n" "$response"
    return 0
  fi

  printf "json\n%s\n" "$response"
}


# –Ю—В—А–Є–Љ–∞—В–Є —Б–µ—А—Ц—Ч
process_playlist() {
    read -r type
    data=$(cat)

    case "$type" in
        json)
            decoded_data=$(printf '%s' "$data" | jq -r .)
            response=$(printf '%s' "$decoded_data" | jq -r .response | tr -d '\n\r')

            temp_dub=$(mktemp)
            temp_sub=$(mktemp)
            temp_final=$(mktemp)

            printf '%s' "$response" | grep -oP '(?<=<li data-id="0_)[0-9]+">[^<]+' | while read -r type_line; do
                type_id=${type_line%%\">*}
                type_name=${type_line#*\">}

                output_file="$temp_dub"
                ([ "$type_name" = "–°–£–С–Ґ–Ш–Ґ–†–Ш" ] || [ "$type_name" = "–°—Г–±—В–Є—В—А–Є" ] || [ "$type_name" = "—Б—Г–±—В–Є—В—А–Є" ]) && output_file="$temp_sub"

                if printf '%s' "$response" | grep -q "data-id=\"0_${type_id}_[0-9]_[0-9]\">"; then
                    printf '%s' "$response" | grep -oP "(?<=<li data-id=\"0_${type_id}_)[0-9]\">[^<]+" | while read -r group_line; do
                        group_id=${group_line%%\">*}
                        group_name=${group_line#*\">}
                        type_id=${type_line%%\">*}
                        type_name=${type_line#*\">}
                        temp_name="$type_name"
                        temp_id="$type_id"

                        #–Ј–∞–Љ—Ц–љ–∞ –≤ –≤–Є–њ–∞–і–Ї—Г –њ–Њ–њ–∞–і–∞–љ–љ—П –љ–Њ–Љ–µ—А—Г –≥—Г—А—В—Г –≤ –Љ—Ц—Б—Ж–µ –і–ї—П –љ–Њ–Љ–µ—А—Г —В–Є–њ—Г
                        [ "$group_name" = "–Ю–Ч–Т–£–І–Х–Э–Э–ѓ" ] || [ "$group_name" = "–Ю–Ј–≤—Г—З–µ–љ–љ—П" ] || [ "$group_name" = "–Њ–Ј–≤—Г—З–µ–љ–љ—П" ] && {
                            [ "$type_name" = "" ] || \
                            type_name="$group_name" && group_name="$temp_name" && output_file="$temp_dub"
                        }
                        [ "$group_name" = "–°–£–С–Ґ–Ш–Ґ–†–Ш" ] || [ "$group_name" = "–°—Г–±—В–Є—В—А–Є" ] || [ "$group_name" = "—Б—Г–±—В–Є—В—А–Є" ] && {
                            [ "$type_name" = "" ] || \
                            type_name="$group_name" && group_name="$temp_name" && output_file="$temp_sub"
                        }

                        printf '%s' "$response" | grep -oP "(?<=<li data-id=\"0_${type_id}_${group_id}_)[0-9]\">[^<]+" | while read -r player_line; do
                            player_id=${player_line%%\">*}
                            player_name=${player_line#*\">}
                            pattern="0_${type_id}_${group_id}_${player_id}"
                            episode_count=$(printf '%s' "$response" | grep -oP "(?<=<li data-file=\")[^\"]+\" data-id=\"${pattern}[^\"]*\">[^<]+" | wc -l)

                            [ "$episode_count" -gt 0 ] && {
                                printf "%s:%s:%s\t%s (—Б–µ—А—Ц–є:%d) {%s}\n" \
                                    "$type_id" "$group_id" "$player_id" \
                                    "$group_name" "$episode_count" "$player_name" >> "$output_file"
                            }
                        done
                    done
                else
                    pattern="0_${type_id}"
                    episode_count=$(printf '%s' "$response" | grep -oP "(?<=<li data-file=\")[^\"]+\" data-id=\"${pattern}[^\"]*\">[^<]+" | wc -l)

                    [ "$episode_count" -gt 0 ] && {
                        printf "%s:%s:%s\t%s (—Б–µ—А—Ц–є:%d)\n" \
                            "$type_id" "0" "0" \
                            "$type_name" "$episode_count" >> "$output_file"
                    }
                fi
            done

            {
                printf "=== –Ю–Ч–Т–£–І–Х–Э–Э–ѓ ===\n"
                [ -s "$temp_dub" ] && {
                    cat "$temp_dub"
                }
                printf "=== –°–£–С–Ґ–Ш–Ґ–†–Ш ===\n"
                [ -s "$temp_sub" ] && {
                    cat "$temp_sub"
                }
            } > "$temp_final"

            selected=$(
                awk '
                /^===/ {
                    printf "%s\t\n", "\t\x1b[1;32m" $0 "\x1b[0m"
                    next
                }
                { print }
                ' "$temp_final" \
                | fzf --layout=reverse \
                    --prompt="–Т–Є–±–µ—А—Ц—В—М –≤–∞—А—Ц–∞–љ—В –і–ї—П $title: " \
                    --with-nth=2.. \
                    --delimiter='\t' \
                    --ansi \
                    --bind="esc:abort" \
                    --cycle
            )

            rm -f "$temp_dub" "$temp_sub" "$temp_final"

            [ -n "$selected" ] && {
                ids=$(printf '%s' "$selected" | cut -f1)
                type_id=${ids%%:*}
                rest=${ids#*:}
                group_id=${rest%%:*}
                player_id=${rest#*:}
        
                if printf '%s' "$response" | grep -q "data-id=\"0_${type_id}_${group_id}_[0-9]\">"; then
                    pattern="0_${type_id}_${group_id}_${player_id}"
                elif printf '%s' "$response" | grep -q "data-id=\"0_${type_id}_[0-9]\">"; then
                    pattern="0_${type_id}_${player_id}"
                else
                    pattern="0_${type_id}"
                fi

                printf '%s\n%s\n%s\n' "$player_url" "$title" "$episode_title" >&2

                printf '%s' "$response" | grep -oP "(?<=<li data-file=\")[^\"]+\" data-id=\"${pattern}[^\"]*\">[^<]+" | while read -r line; do
                    player_url=${line%\" data-id=*}
                    episode_title=${line#*\">}
                    [ -n "$player_url" ] && [ -n "$episode_title" ] && printf '%s\t%s\n' "$episode_title" "$player_url"
                done
            }
        ;;
        html)
            decoded_data=$(printf '%s' "$data" | awk '
            {
                while (match($0, /\\u[0-9a-fA-F]{4}/)) {
                    hex = substr($0, RSTART+2, 4)
                    char = sprintf("%c", strtonum("0x" hex))
                    $0 = substr($0, 1, RSTART-1) char substr($0, RSTART+RLENGTH)
                }
                print
            }' | tr -d '\\')
            
            printf '%s\n%s\n%s\n' "$player_url" "$title" "$episode_title" >&2
        
            printf '%s' "$decoded_data" | grep -oP '\{"name":"[^"]+","code":"<iframe src="[^"]+"' | while read -r episode; do
                
                episode_title=$(printf '%s' "$episode" | grep -oP '(?<={"name":")[^"]+')
                player_url=$(printf '%s' "$episode" | grep -oP '(?<=src=")[^"]+')

                [ -n "$player_url" ] && [ -n "$episode_title" ] && printf '%s\t%s\n' "$episode_title" "$player_url"
            done
            ;;
    esac
}


